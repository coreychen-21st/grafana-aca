#!/usr/bin/env bash
# Setup alerts for Prod App Service Plans from prod_asp.json
# Rules: WARNING(80%/60min) + CRITICAL(90%/30min)

set -euo pipefail

PROD_ASP_FILE="prod_asp.json"
LOG_FILE="asp_alert_apply_$(date +%Y%m%d_%H%M%S).log"
ACTION_GROUP_NAME="Action Send Alert"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

log_info() { echo -e "${GREEN}[$(date '+%Y-%m-%d %H:%M:%S')]${NC} $*" | tee -a "$LOG_FILE"; }
log_warn() { echo -e "${YELLOW}[$(date '+%Y-%m-%d %H:%M:%S')]${NC} $*" | tee -a "$LOG_FILE"; }
log_error() { echo -e "${RED}[$(date '+%Y-%m-%d %H:%M:%S')]${NC} $*" | tee -a "$LOG_FILE" >&2; }

declare -A SKU_BW_BYTES_MIN=([P0v3]="781250000" [P1v3]="1562500000" [P2v3]="3125000000" [P3v3]="6250000000" [DEFAULT]="781250000")
declare -A SKU_HTTP_QUEUE=([P0v3]="500" [P1v3]="1000" [P2v3]="2000" [P3v3]="4000" [DEFAULT]="500")

calc_threshold() { echo "$1 $2" | awk '{printf "%.0f", $1 * $2 / 100}'; }

check_prerequisites() {
    log_info "==> Check prerequisites..."
    command -v az &>/dev/null || { log_error "Azure CLI not installed"; exit 1; }
    command -v jq &>/dev/null || { log_error "jq not installed"; exit 1; }
    az account show &>/dev/null || { log_error "Not logged into Azure"; exit 1; }
    [[ -f "$PROD_ASP_FILE" ]] || { log_error "$PROD_ASP_FILE not found"; exit 1; }
    log_info "    OK"
}

resolve_action_group() {
    local sub_id="$1" rg="$2"
    log_info "    檢查 Action Group in RG: $rg"
    local ag_id=$(az monitor action-group show --name "$ACTION_GROUP_NAME" \
        --resource-group "$rg" --subscription "$sub_id" --query "id" -o tsv 2>/dev/null || echo "")
    if [[ -n "$ag_id" ]]; then
        log_info "    找到 Action Group"
        echo "$ag_id"
        return 0
    fi
    log_error "    找不到 Action Group '$ACTION_GROUP_NAME'"
    echo ""
    return 1
}

create_alert() {
    local rule_name="$1" resource_id="$2" metric="$3" threshold="$4"
    local window_min="$5" severity="$6" description="$7" resource_group="$8" subscription_id="$9"
    local window="PT${window_min}M" freq="PT5M"

    # 檢查是否已存在
    if az monitor metrics alert show --name "$rule_name" --resource-group "$resource_group" \
        --subscription "$subscription_id" --query "name" -o tsv 2>/dev/null | grep -q "$rule_name"; then
        log_info "    [SKIP] $rule_name"
        return 0
    fi

    local condition="avg ${metric} > ${threshold}"
    local result
    result=$(az monitor metrics alert create --name "$rule_name" --resource-group "$resource_group" \
        --subscription "$subscription_id" --scopes "$resource_id" \
        --condition "$condition" \
        --window-size "$window" --evaluation-frequency "$freq" \
        --severity "$severity" --description "$description" \
        --action "$ACTION_GROUP_ID" \
        --tags "environment=prod" "managed-by=setup_asp_alerts" \
        --output json 2>&1)

    # 檢查是否有 error
    if echo "$result" | jq -e '.error' >/dev/null 2>&1; then
        local err_msg=$(echo "$result" | jq -r '.error.message // "Unknown error"' | head -c 100)
        log_error "    [FAIL] $rule_name: $err_msg"
        return 1
    fi

    log_info "    [OK] $rule_name (${window_min}min > ${threshold})"
    return 0
}

create_alerts_for_asp() {
    local asp="$1"
    local ASP_NAME=$(echo "$asp" | jq -r '.name')
    local RG=$(echo "$asp" | jq -r '.resourceGroup')
    local SUB_ID=$(echo "$asp" | jq -r '.subscriptionId')
    local SKU=$(echo "$asp" | jq -r '.sku // "DEFAULT"' | tr '[:lower:]' '[:upper:]')

    local RESOURCE_ID="/subscriptions/${SUB_ID}/resourceGroups/${RG}/providers/Microsoft.Web/serverfarms/${ASP_NAME}"
    local BW_MAX="${SKU_BW_BYTES_MIN[$SKU]:-${SKU_BW_BYTES_MIN[DEFAULT]}}"
    local HTTP_Q_MAX="${SKU_HTTP_QUEUE[$SKU]:-${SKU_HTTP_QUEUE[DEFAULT]}}"

    log_info ""
    log_info ">> $RG/$ASP_NAME (SKU: $SKU)"

    local NET_WARN=$(calc_threshold "$BW_MAX" 80)
    local NET_CRIT=$(calc_threshold "$BW_MAX" 90)
    local HTTP_Q_WARN=$(calc_threshold "$HTTP_Q_MAX" 80)
    local HTTP_Q_CRIT=$(calc_threshold "$HTTP_Q_MAX" 90)

    local PREFIX="asp-prod-$(echo "${ASP_NAME}" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9]/-/g' | cut -c1-30)"
    local failed=0

    create_alert "${PREFIX}-cpu-warn" "$RESOURCE_ID" "CpuPercentage" "80" "60" "2" \
        "[PROD][WARNING] CPU > 80% (60min)" "$RG" "$SUB_ID" || failed=1
    create_alert "${PREFIX}-cpu-crit" "$RESOURCE_ID" "CpuPercentage" "90" "30" "1" \
        "[PROD][CRITICAL] CPU > 90% (30min)" "$RG" "$SUB_ID" || failed=1

    create_alert "${PREFIX}-mem-warn" "$RESOURCE_ID" "MemoryPercentage" "80" "60" "2" \
        "[PROD][WARNING] Memory > 80% (60min)" "$RG" "$SUB_ID" || failed=1
    create_alert "${PREFIX}-mem-crit" "$RESOURCE_ID" "MemoryPercentage" "90" "30" "1" \
        "[PROD][CRITICAL] Memory > 90% (30min)" "$RG" "$SUB_ID" || failed=1

    create_alert "${PREFIX}-disk-warn" "$RESOURCE_ID" "DiskQueueLength" "80" "60" "2" \
        "[PROD][WARNING] DiskQueue > 80 (60min)" "$RG" "$SUB_ID" || failed=1
    create_alert "${PREFIX}-disk-crit" "$RESOURCE_ID" "DiskQueueLength" "90" "30" "1" \
        "[PROD][CRITICAL] DiskQueue > 90 (30min)" "$RG" "$SUB_ID" || failed=1

    create_alert "${PREFIX}-netin-warn" "$RESOURCE_ID" "BytesReceived" "$NET_WARN" "60" "2" \
        "[PROD][WARNING] Network In > 80% (60min)" "$RG" "$SUB_ID" || failed=1
    create_alert "${PREFIX}-netin-crit" "$RESOURCE_ID" "BytesReceived" "$NET_CRIT" "30" "1" \
        "[PROD][CRITICAL] Network In > 90% (30min)" "$RG" "$SUB_ID" || failed=1

    create_alert "${PREFIX}-netout-warn" "$RESOURCE_ID" "BytesSent" "$NET_WARN" "60" "2" \
        "[PROD][WARNING] Network Out > 80% (60min)" "$RG" "$SUB_ID" || failed=1
    create_alert "${PREFIX}-netout-crit" "$RESOURCE_ID" "BytesSent" "$NET_CRIT" "30" "1" \
        "[PROD][CRITICAL] Network Out > 90% (30min)" "$RG" "$SUB_ID" || failed=1

    create_alert "${PREFIX}-httpq-warn" "$RESOURCE_ID" "HttpQueueLength" "$HTTP_Q_WARN" "60" "2" \
        "[PROD][WARNING] HTTP Queue > 80% (60min)" "$RG" "$SUB_ID" || failed=1
    create_alert "${PREFIX}-httpq-crit" "$RESOURCE_ID" "HttpQueueLength" "$HTTP_Q_CRIT" "30" "1" \
        "[PROD][CRITICAL] HTTP Queue > 90% (30min)" "$RG" "$SUB_ID" || failed=1

    if [[ $failed -eq 0 ]]; then
        log_info "   完成: 12 條 Alert Rules"
    else
        log_warn "   部分失敗: $failed 條"
    fi
}

process_subscription() {
    local sub_id="$1" sub_name="$2"
    local sub_plans="$3"
    local first_rg=$(echo "$sub_plans" | jq -r '.[0].resourceGroup')

    log_info ""
    log_info "============================================"
    log_info " 處理 Subscription: $sub_name"
    log_info "============================================"

    ACTION_GROUP_ID=$(resolve_action_group "$sub_id" "$first_rg") || return 1

    while IFS= read -r asp; do
        create_alerts_for_asp "$asp"
    done < <(echo "$sub_plans" | jq -c '.[]')
}

main() {
    echo "============================================"
    echo " Azure App Service Plan Alert Setup"
    echo " $(date)"
    echo "============================================"
    echo ""

    check_prerequisites

    PROD_PLANS=$(cat "$PROD_ASP_FILE")
    PROD_COUNT=$(echo "$PROD_PLANS" | jq 'length')
    log_info "==> Found $PROD_COUNT Prod App Service Plans"

    echo ""
    echo "============================================"
    echo " Prod App Service Plans (Total: $PROD_COUNT)"
    echo "============================================"
    echo "$PROD_PLANS" | jq -r '.[] | "  [\(.subscriptionName)] \(.resourceGroup)/\(.name)"'
    echo ""

    log_info "==> 按 Subscription 分組處理..."

    local sub_ids=$(echo "$PROD_PLANS" | jq -r '.[].subscriptionId' | sort -u)

    while IFS= read -r sub_id; do
        local sub_name=$(echo "$PROD_PLANS" | jq --arg s "$sub_id" -r '.[] | select(.subscriptionId==$s) | .subscriptionName' | head -1)
        local sub_plans=$(echo "$PROD_PLANS" | jq --arg sub "$sub_id" '[.[] | select(.subscriptionId==$sub)]')
        process_subscription "$sub_id" "$sub_name" "$sub_plans"
    done <<< "$sub_ids"

    echo ""
    log_info "============================================"
    log_info " 完成"
    log_info "   Log: $LOG_FILE"
    log_info "============================================"
}

main "$@"
