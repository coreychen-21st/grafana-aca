{
  "_comment": "Grafana Alert Rules Template for Azure App Service Plan - Prod",
  "_version": "3.0.0",
  "_resourceType": "AppServicePlan",
  "_metricNamespace": "Microsoft.Web/serverfarms",
  "_variablePlaceholders": {
    "AZURE_DATASOURCE_UID": "Azure Monitor datasource UID in Grafana",
    "RESOURCE_GROUP": "Azure resource group name",
    "RESOURCE_NAME": "App Service Plan name",
    "SUBSCRIPTION_ID": "Azure subscription ID",
    "NET_IN_WARN_BYTES": "Network In warning threshold (bytes/min, computed from SKU bandwidth * 0.8)",
    "NET_IN_CRIT_BYTES": "Network In critical threshold (bytes/min, computed from SKU bandwidth * 0.9)",
    "NET_OUT_WARN_BYTES": "Network Out warning threshold (bytes/min, computed from SKU bandwidth * 0.8)",
    "NET_OUT_CRIT_BYTES": "Network Out critical threshold (bytes/min, computed from SKU bandwidth * 0.9)",
    "SOCK_OUT_WARN": "Socket Outbound warning threshold (computed from socket_max * 0.8)",
    "SOCK_OUT_CRIT": "Socket Outbound critical threshold (computed from socket_max * 0.9)",
    "DISK_WARN_THRESHOLD": "Disk Queue warning threshold (computed from SKU disk queue max * 0.8)",
    "DISK_CRIT_THRESHOLD": "Disk Queue critical threshold (computed from SKU disk queue max * 0.9)"
  },
  "groups": [
    {
      "name": "ASP-Prod-CPU",
      "interval": "1m",
      "rules": [
        {
          "uid": "asp-prod-cpu-warn",
          "title": "[WARN] ${RESOURCE_NAME} - CPU > 80% (60min)",
          "condition": "C",
          "data": [
            {
              "refId": "A",
              "datasourceUid": "${AZURE_DATASOURCE_UID}",
              "queryType": "Azure Monitor",
              "model": {
                "azureMonitor": {
                  "resourceGroup": "${RESOURCE_GROUP}",
                  "resourceName": "${RESOURCE_NAME}",
                  "metricNamespace": "Microsoft.Web/serverfarms",
                  "metricName": "CpuPercentage",
                  "timeGrain": "PT1M",
                  "aggregation": "Average",
                  "subscriptionId": "${SUBSCRIPTION_ID}"
                },
                "queryType": "Azure Monitor",
                "subscription": "${SUBSCRIPTION_ID}"
              },
              "relativeTimeRange": { "from": 3600, "to": 0 }
            },
            {
              "refId": "B",
              "datasourceUid": "-100",
              "model": { "type": "reduce", "expression": "A", "reducer": "mean", "settings": {} },
              "queryType": "",
              "relativeTimeRange": { "from": 0, "to": 0 }
            },
            {
              "refId": "C",
              "datasourceUid": "-100",
              "model": {
                "type": "threshold",
                "inputSeries": "B",
                "conditions": [
                  {
                    "evaluator": { "params": [80], "type": "gt" },
                    "operator": { "type": "and" },
                    "query": { "params": ["B"] },
                    "reducer": { "params": [], "type": "last" },
                    "type": "query"
                  }
                ],
                "expression": "B"
              },
              "queryType": "",
              "relativeTimeRange": { "from": 0, "to": 0 }
            }
          ],
          "noDataState": "NoData",
          "execErrState": "Error",
          "for": "60m",
          "labels": { "severity": "warning", "environment": "prod", "resource_type": "app_service_plan", "metric": "cpu" },
          "annotations": {
            "summary": "App Service Plan CPU > 80%",
            "description": "${RESOURCE_NAME} CPU 平均使用率在過去 60 分鐘持續超過 80%。目前值: {{ $values.B.Value | printf \"%.1f\" }}%",
            "runbook_url": "https://wiki.internal/runbook/asp-cpu-high"
          }
        },
        {
          "uid": "asp-prod-cpu-crit",
          "title": "[CRIT] ${RESOURCE_NAME} - CPU > 90% (30min)",
          "condition": "C",
          "data": [
            {
              "refId": "A",
              "datasourceUid": "${AZURE_DATASOURCE_UID}",
              "queryType": "Azure Monitor",
              "model": {
                "azureMonitor": {
                  "resourceGroup": "${RESOURCE_GROUP}",
                  "resourceName": "${RESOURCE_NAME}",
                  "metricNamespace": "Microsoft.Web/serverfarms",
                  "metricName": "CpuPercentage",
                  "timeGrain": "PT1M",
                  "aggregation": "Average",
                  "subscriptionId": "${SUBSCRIPTION_ID}"
                },
                "queryType": "Azure Monitor",
                "subscription": "${SUBSCRIPTION_ID}"
              },
              "relativeTimeRange": { "from": 1800, "to": 0 }
            },
            {
              "refId": "B",
              "datasourceUid": "-100",
              "model": { "type": "reduce", "expression": "A", "reducer": "mean", "settings": {} },
              "queryType": "",
              "relativeTimeRange": { "from": 0, "to": 0 }
            },
            {
              "refId": "C",
              "datasourceUid": "-100",
              "model": {
                "type": "threshold",
                "inputSeries": "B",
                "conditions": [
                  {
                    "evaluator": { "params": [90], "type": "gt" },
                    "operator": { "type": "and" },
                    "query": { "params": ["B"] },
                    "reducer": { "params": [], "type": "last" },
                    "type": "query"
                  }
                ],
                "expression": "B"
              },
              "queryType": "",
              "relativeTimeRange": { "from": 0, "to": 0 }
            }
          ],
          "noDataState": "NoData",
          "execErrState": "Error",
          "for": "30m",
          "labels": { "severity": "critical", "environment": "prod", "resource_type": "app_service_plan", "metric": "cpu" },
          "annotations": {
            "summary": "App Service Plan CPU > 90% - CRITICAL",
            "description": "${RESOURCE_NAME} CPU 平均使用率在過去 30 分鐘持續超過 90%。目前值: {{ $values.B.Value | printf \"%.1f\" }}%。請立即處理！",
            "runbook_url": "https://wiki.internal/runbook/asp-cpu-high"
          }
        }
      ]
    },
