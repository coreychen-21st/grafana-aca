{
  "_comment": "Grafana Alert Rules Template for Azure Redis Managed (Azure Cache for Redis) - Prod",
  "_version": "1.0.0",
  "_resourceType": "Redis",
  "_metricNamespace": "Microsoft.Cache/redis",
  "_variablePlaceholders": {
    "AZURE_DATASOURCE_UID": "Azure Monitor datasource UID in Grafana",
    "RESOURCE_GROUP": "Azure resource group name",
    "RESOURCE_NAME": "Redis cache name",
    "SUBSCRIPTION_ID": "Azure subscription ID"
  },
  "groups": [
    {
      "name": "Redis-Prod-Memory",
      "interval": "5m",
      "rules": [
        {
          "uid": "redis-prod-mem-warn",
          "title": "[WARN] ${RESOURCE_NAME} - Memory > 80% (60min)",
          "condition": "C",
          "data": [
            {
              "refId": "A",
              "datasourceUid": "${AZURE_DATASOURCE_UID}",
              "queryType": "Azure Monitor",
              "model": {
                "azureMonitor": {
                  "resourceGroup": "${RESOURCE_GROUP}",
                  "resourceName": "${RESOURCE_NAME}",
                  "metricNamespace": "Microsoft.Cache/redis",
                  "metricName": "usedmemorypercentage",
                  "timeGrain": "PT1M",
                  "aggregation": "Average",
                  "subscriptionId": "${SUBSCRIPTION_ID}"
                },
                "queryType": "Azure Monitor",
                "subscription": "${SUBSCRIPTION_ID}"
              },
              "relativeTimeRange": { "from": 3600, "to": 0 }
            },
            {
              "refId": "B",
              "datasourceUid": "-100",
              "model": { "type": "reduce", "expression": "A", "reducer": "mean", "settings": {} },
              "queryType": "",
              "relativeTimeRange": { "from": 0, "to": 0 }
            },
            {
              "refId": "C",
              "datasourceUid": "-100",
              "model": {
                "type": "threshold",
                "inputSeries": "B",
                "conditions": [
                  {
                    "evaluator": { "params": [80], "type": "gt" },
                    "operator": { "type": "and" },
                    "query": { "params": ["B"] },
                    "reducer": { "params": [], "type": "last" },
                    "type": "query"
                  }
                ],
                "expression": "B"
              },
              "queryType": "",
              "relativeTimeRange": { "from": 0, "to": 0 }
            }
          ],
          "noDataState": "NoData",
          "execErrState": "Error",
          "for": "60m",
          "labels": { "severity": "warning", "environment": "prod", "resource_type": "redis", "metric": "memory" },
          "annotations": {
            "summary": "Redis Memory > 80%",
            "description": "${RESOURCE_NAME} usedmemorypercentage 在過去 60 分鐘平均超過 80%。目前值: {{ $values.B.Value | printf \"%.1f\" }}%",
            "runbook_url": "https://wiki.internal/runbook/redis-memory-high"
          }
        },
        {
          "uid": "redis-prod-mem-crit",
          "title": "[CRIT] ${RESOURCE_NAME} - Memory > 90% (30min)",
          "condition": "C",
          "data": [
            {
              "refId": "A",
              "datasourceUid": "${AZURE_DATASOURCE_UID}",
              "queryType": "Azure Monitor",
              "model": {
                "azureMonitor": {
                  "resourceGroup": "${RESOURCE_GROUP}",
                  "resourceName": "${RESOURCE_NAME}",
                  "metricNamespace": "Microsoft.Cache/redis",
                  "metricName": "usedmemorypercentage",
                  "timeGrain": "PT1M",
                  "aggregation": "Average",
                  "subscriptionId": "${SUBSCRIPTION_ID}"
                },
                "queryType": "Azure Monitor",
                "subscription": "${SUBSCRIPTION_ID}"
              },
              "relativeTimeRange": { "from": 1800, "to": 0 }
            },
            {
              "refId": "B",
              "datasourceUid": "-100",
              "model": { "type": "reduce", "expression": "A", "reducer": "mean", "settings": {} },
              "queryType": "",
              "relativeTimeRange": { "from": 0, "to": 0 }
            },
            {
              "refId": "C",
              "datasourceUid": "-100",
              "model": {
                "type": "threshold",
                "inputSeries": "B",
                "conditions": [
                  {
                    "evaluator": { "params": [90], "type": "gt" },
                    "operator": { "type": "and" },
                    "query": { "params": ["B"] },
                    "reducer": { "params": [], "type": "last" },
                    "type": "query"
                  }
                ],
                "expression": "B"
              },
              "queryType": "",
              "relativeTimeRange": { "from": 0, "to": 0 }
            }
          ],
          "noDataState": "NoData",
          "execErrState": "Error",
          "for": "30m",
          "labels": { "severity": "critical", "environment": "prod", "resource_type": "redis", "metric": "memory" },
          "annotations": {
            "summary": "Redis Memory > 90% - CRITICAL",
            "description": "${RESOURCE_NAME} usedmemorypercentage 在過去 30 分鐘平均超過 90%。目前值: {{ $values.B.Value | printf \"%.1f\" }}%。請立即處理！",
            "runbook_url": "https://wiki.internal/runbook/redis-memory-high"
          }
        }
      ]
    },
