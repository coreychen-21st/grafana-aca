{
  "_comment": "Grafana Alert Rules Template for Azure App Service Plan - Prod (BACKUP MODE)",
  "_version": "2.0.0",
  "_mode": "backup",
  "_primary": "Azure Monitor (02_azure_monitor_alert_rules.sh)",
  "_rules": "WARNING: 90min > 80% | CRITICAL: 45min > 90% (備用模式，eval interval=10m)",
  "_note": "此 template 由 03_apply_grafana_alerts.sh 使用，定位為備用告警。主要告警由 Azure Monitor 負責。",
  "groups": [
    {
      "name": "AppServicePlan-Prod-CPU",
      "interval": "1m",
      "rules": [
        {
          "uid": "asp-prod-cpu-warn",
          "title": "[WARN] ${RESOURCE_NAME} - CPU Warning > 80% (60min)",
          "condition": "C",
          "data": [
            {
              "refId": "A",
              "datasourceUid": "${AZURE_DATASOURCE_UID}",
              "queryType": "Azure Monitor",
              "model": {
                "azureMonitor": {
                  "resourceGroup": "${RESOURCE_GROUP}",
                  "resourceName": "${ASP_NAME}",
                  "metricNamespace": "Microsoft.Web/serverfarms",
                  "metricName": "CpuPercentage",
                  "timeGrain": "PT1M",
                  "aggregation": "Average",
                  "subscriptionId": "${SUBSCRIPTION_ID}"
                },
                "queryType": "Azure Monitor",
                "subscription": "${SUBSCRIPTION_ID}"
              },
              "relativeTimeRange": {
                "from": 3600,
                "to": 0
              }
            },
            {
              "refId": "B",
              "datasourceUid": "-100",
              "model": {
                "type": "reduce",
                "expression": "A",
                "reducer": "mean",
                "settings": {}
              },
              "queryType": "",
              "relativeTimeRange": {
                "from": 0,
                "to": 0
              }
            },
            {
              "refId": "C",
              "datasourceUid": "-100",
              "model": {
                "type": "threshold",
                "inputSeries": "B",
                "conditions": [
                  {
                    "evaluator": {
                      "params": [
                        80
                      ],
                      "type": "gt"
                    },
                    "operator": {
                      "type": "and"
                    },
                    "query": {
                      "params": [
                        "B"
                      ]
                    },
                    "reducer": {
                      "params": [],
                      "type": "last"
                    },
                    "type": "query"
                  }
                ],
                "expression": "B"
              },
              "queryType": "",
              "relativeTimeRange": {
                "from": 0,
                "to": 0
              }
            }
          ],
          "noDataState": "NoData",
          "execErrState": "Error",
          "for": "60m",
          "labels": {
            "severity": "warning",
            "environment": "prod",
            "resource_type": "app_service_plan",
            "metric": "cpu"
          },
          "annotations": {
            "summary": "App Service Plan CPU 使用率超過 80%",
            "description": "App Service Plan ${RESOURCE_NAME} 的 CPU 平均使用率在過去 60 分鐘持續超過 80%。目前值: {{ $values.B.Value | printf \"%.1f\" }}%",
            "runbook_url": "https://wiki.internal/runbook/asp-cpu-high"
          }
        },
        {
          "uid": "asp-prod-cpu-crit",
          "title": "[CRIT] ${RESOURCE_NAME} - CPU Critical > 90% (30min)",
          "condition": "C",
          "data": [
            {
              "refId": "A",
              "datasourceUid": "${AZURE_DATASOURCE_UID}",
              "queryType": "Azure Monitor",
              "model": {
                "azureMonitor": {
                  "resourceGroup": "${RESOURCE_GROUP}",
                  "resourceName": "${ASP_NAME}",
                  "metricNamespace": "Microsoft.Web/serverfarms",
                  "metricName": "CpuPercentage",
                  "timeGrain": "PT1M",
                  "aggregation": "Average",
                  "subscriptionId": "${SUBSCRIPTION_ID}"
                },
                "queryType": "Azure Monitor",
                "subscription": "${SUBSCRIPTION_ID}"
              },
              "relativeTimeRange": {
                "from": 1800,
                "to": 0
              }
            },
            {
              "refId": "B",
              "datasourceUid": "-100",
              "model": {
                "type": "reduce",
                "expression": "A",
                "reducer": "mean",
                "settings": {}
              },
              "queryType": "",
              "relativeTimeRange": {
                "from": 0,
                "to": 0
              }
            },
            {
              "refId": "C",
              "datasourceUid": "-100",
              "model": {
                "type": "threshold",
                "inputSeries": "B",
                "conditions": [
                  {
                    "evaluator": {
                      "params": [
                        90
                      ],
                      "type": "gt"
                    },
                    "operator": {
                      "type": "and"
                    },
                    "query": {
                      "params": [
                        "B"
                      ]
                    },
                    "reducer": {
                      "params": [],
                      "type": "last"
                    },
                    "type": "query"
                  }
                ],
                "expression": "B"
              },
              "queryType": "",
              "relativeTimeRange": {
                "from": 0,
                "to": 0
              }
            }
          ],
          "noDataState": "NoData",
          "execErrState": "Error",
          "for": "30m",
          "labels": {
            "severity": "critical",
            "environment": "prod",
            "resource_type": "app_service_plan",
            "metric": "cpu"
          },
          "annotations": {
            "summary": "App Service Plan CPU 使用率超過 90% - 緊急",
            "description": "App Service Plan ${RESOURCE_NAME} 的 CPU 平均使用率在過去 30 分鐘持續超過 90%。目前值: {{ $values.B.Value | printf \"%.1f\" }}%。請立即處理！",
            "runbook_url": "https://wiki.internal/runbook/asp-cpu-high"
          }
